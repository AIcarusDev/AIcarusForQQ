{
  "type": "object",
  "description": "你的内心状态和行为决策。",
  "properties": {
    "mood": {
      "type": "string",
      "description": "你当前的情绪，是下意识的第一反应。"
    },
    "think": {
      "type": "string",
      "description": "你当前的内心想法，自然衔接而非重复你上一轮(`<previous_cycle>`)的想法，是真实且私密的。应该是非常丰富的深度思考。包括心理状态以及对目前情况的充分感知和理解，例如：在想什么？发生了什么？已经过去了多久？谁在跟谁说话？别人的话说完了吗？现在发消息合适吗？如果要发 大概表达什么内容？等等。"
    },
    "intent": {
      "type": "string",
      "description": "你当前最直接的、短期的意图或打算。"
    },
    "decision": {
      "type": "object",
      "title": "行为决策",
      "description": "基于你的心情、想法、意图，当前外界情况等等，你可以选择做些什么，或是什么都不做。",
      "properties": {
        "send_messages": {
          "type": "array",
          "title": "发送消息",
          "description": "发送一条或多条消息。数组中的每一个元素代表一条独立发送的消息。长消息可以拆分为多条消息（即数组中的多个元素）",
          "items": {
            "type": "object",
            "description": "单条消息的结构",
            "properties": {
              "quote": {
                "type": ["string", "null"],
                "title": "引用/回复",
                "description": "要引用或明确回复的目标消息ID。需要明确这条消息引用/回复某条先前的消息时使用。"
              },
              "segments": {
                "type": "array",
                "description": "该条消息的具体内容片段（文本或@某人）",
                "items": {
                  "oneOf": [
                    {
                      "title": "@某人",
                      "type": "object",
                      "properties": {
                        "command": {
                          "type": "string",
                          "enum": ["at"]
                        },
                        "params": {
                          "type": "object",
                          "properties": {
                            "user_id": {
                              "type": "string",
                              "description": "要 @ 用户的 ID"
                            }
                          },
                          "required": ["user_id"]
                        }
                      },
                      "required": ["command", "params"]
                    },
                    {
                      "title": "打字文本",
                      "type": "object",
                      "properties": {
                        "command": {
                          "type": "string",
                          "enum": ["text"]
                        },
                        "params": {
                          "type": "object",
                          "properties": {
                            "content": {
                              "type": "string",
                              "description": "文本内容，建议控制单条消息长度（例如 10 字以下），标点符号可省略"
                            }
                          },
                          "required": ["content"]
                        }
                      },
                      "required": ["command", "params"]
                    },
                    {
                      "title": "发送表情包",
                      "type": "object",
                      "properties": {
                        "command": {
                          "type": "string",
                          "enum": ["sticker"]
                        },
                        "params": {
                          "type": "object",
                          "properties": {
                            "sticker_id": {
                              "type": "string",
                              "description": "已收藏的表情包 ID，例如 \"000\"。可通过 list_stickers 工具查询。如果决定发送表情包，建议本条消息只包含表情包一个片段，而不是与文字混杂。"
                            }
                          },
                          "required": ["sticker_id"]
                        }
                      },
                      "required": ["command", "params"]
                    }
                  ]
                }
              }
            },
            "required": ["segments"]
          }
        },
        "motivation": {
          "type": "string",
          "description": "你这么做（或什么都不做）的原因。"
        }
      },
      "required": ["motivation"]
    },
    "expected": {
      "type": "string",
      "title": "期望、预期",
      "description": "做完这些（或什么都不做）后，你期望的结果或事态发展。"
    },
    "loop_control": {
      "type": "object",
      "title": "循环管理",
      "description": "决定你下一步动作。",
      "properties": {
        "continue": {
          "type": "object",
          "description": "专注于当前会话，立即开始下一次循环。",
          "additionalProperties": false
        },
        "idle": {
          "type": "object",
          "description": "暂时不再专注于当前会话，进入窥屏围观（对于非延续的 简单的交互来说可以优先考虑）。",
          "additionalProperties": false
        },
        "wait": {
          "type": "object",
          "description": "专注于当前会话并且等待，等待一定时间或满足提前唤醒条件后进入下一次循环（如果你察觉到对方的话看起来没说完，还会继续补充更多信息，优先考虑不发言并且选择\"wait\"，同时不设定\"early_trigger\"，并且设定一个较短的等待时间）。",
          "properties": {
            "timeout": {
              "type": "integer",
              "minimum": 1,
              "maximum": 300,
              "description": "最长等待秒数，超时后自动继续下一轮循环。"
            },
            "early_trigger": {
              "type": "string",
              "enum": ["new_message", "mentioned"],
              "description": "提前唤醒条件（可选）。\"new_message\"：收到任意新消息；\"mentioned\"：被 @ 或被引用回复时。"
            }
          },
          "required": ["timeout"],
          "additionalProperties": false
        },
        "shift": {
          "type": "object",
          "description": "切换到另一个会话并立即激活一次循环。如果目标会话不在项目白名单或 QQ 好友/群列表中，切换将失败。",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["private", "group"],
              "description": "目标会话类型：私聊或群聊。"
            },
            "id": {
              "type": "string",
              "description": "目标会话 ID：私聊为目标用户 QQ 号，群聊为群号。"
            }
          },
          "required": ["type", "id"],
          "additionalProperties": false
        },
        "motivation": { "type": "string" }
      },
      "required": ["motivation"],
      "oneOf": [
        { "required": ["continue"] },
        { "required": ["idle"] },
        { "required": ["wait"] },
        { "required": ["shift"] }
      ]
    }
  },
  "required": [
    "mood",
    "think",
    "intent",
    "decision",
    "expected",
    "loop_control"
  ]
}
