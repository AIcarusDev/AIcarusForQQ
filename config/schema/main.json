{
  "type": "object",
  "description": "你的内心状态和最终行为决策。",
  "properties": {
    "mood": {
      "type": "string",
      "description": "你当前的情绪，是下意识的第一反应。"
    },
    "think": {
      "type": "string",
      "description": "你当前的内心想法，是自然、真实且私密的。可以简短，也可以是非常丰富的深度思考。或是在这里进行对当前情况的认知理解。"
    },
    "intent": {
      "type": "string",
      "description": "你当前最直接的、短期的意图或打算。"
    },
    "decision": {
      "type": "object",
      "title": "行为决策",
      "description": "基于你的心情、想法、意图，当前外界情况等等，你可以选择做些什么，或是什么都不做。",
      "properties": {
        "send_messages": {
          "type": "array",
          "title": "发送消息",
          "description": "发送一条或多条消息。数组中的每一个元素代表一条独立发送的消息。长消息可以拆分为多条消息（即数组中的多个元素），而非将所有内容堆入同一条消息的 segments 中。通常情况下建议：一条消息控制在 10 字以下，消息中的标点符号均可省略，并且自然口语化。回复长度匹配对话本身：例如玩笑、闲聊、简单互动默认一两句话，不用堆砌内容；只有当你觉得想要 或需要时才发送多条消息。",
          "items": {
            "type": "object",
            "description": "单条消息的结构",
            "properties": {
              "quote": {
                "type": ["string", "null"],
                "title": "引用",
                "description": "要引用或明确回复的目标消息ID。仅在需要明确上下文或特别提醒时使用，不要滥用。"
              },
              "segments": {
                "type": "array",
                "description": "该条消息的具体内容片段（文本或@某人）",
                "items": {
                  "oneOf": [
                    {
                      "title": "@某人",
                      "type": "object",
                      "properties": {
                        "command": {
                          "type": "string",
                          "enum": ["at"]
                        },
                        "params": {
                          "type": "object",
                          "properties": {
                            "user_id": {
                              "type": "string",
                              "description": "被 @ 用户的 ID"
                            }
                          },
                          "required": ["user_id"]
                        }
                      },
                      "required": ["command", "params"]
                    },
                    {
                      "title": "文本",
                      "type": "object",
                      "properties": {
                        "command": {
                          "type": "string",
                          "enum": ["text"]
                        },
                        "params": {
                          "type": "object",
                          "properties": {
                            "content": {
                              "type": "string",
                              "description": "文本内容，建议控制单条消息长度（例如 10 字以下）"
                            }
                          },
                          "required": ["content"]
                        }
                      },
                      "required": ["command", "params"]
                    }
                  ]
                }
              }
            },
            "required": ["segments"]
          }
        },
        "motivation": {
          "type": "string",
          "description": "你这么做（或什么都不做）的原因。"
        }
      },
      "required": ["motivation"]
    },
    "expected": {
      "type": "string",
      "title": "期望、预期",
      "description": "做完这些（或什么都不做）后，你期望的结果或事态发展。"
    },
    "loop_control": {
      "type": "object",
      "title": "循环管理",
      "description": "决定本轮结束后的下一步动作。三选一：continue（立即继续）、break（暂停等待激活）、wait（定时或条件唤醒）。当剩余连续循环次数为 0 时，只能选 break。",
      "properties": {
        "continue": {
          "type": "object",
          "description": "立即开始下一次循环（消耗一次剩余循环次数）。",
          "additionalProperties": false
        },
        "break": {
          "type": "object",
          "description": "结束当前循环，等待被动激活。",
          "additionalProperties": false
        },
        "wait": {
          "type": "object",
          "description": "挂起当前循环，到达超时时间或满足提前唤醒条件后自动继续下一轮。",
          "properties": {
            "timeout": {
              "type": "integer",
              "minimum": 1,
              "maximum": 300,
              "description": "最长等待秒数，超时后自动继续下一轮循环。"
            },
            "early_trigger": {
              "type": "string",
              "enum": ["new_message", "mentioned"],
              "description": "提前唤醒条件（可选）。new_message：收到任意新消息；mentioned：被 @ 或被引用回复时。"
            }
          },
          "required": ["timeout"],
          "additionalProperties": false
        },
        "motivation": { "type": "string" }
      },
      "required": ["motivation"],
      "oneOf": [
        { "required": ["continue"] },
        { "required": ["break"] },
        { "required": ["wait"] }
      ]
    }
  },
  "required": [
    "mood",
    "think",
    "intent",
    "decision",
    "expected",
    "loop_control"
  ]
}
