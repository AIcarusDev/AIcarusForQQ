{
  "type": "object",
  "description": "你的内心状态和行为决策。",
  "properties": {
    "mood": {
      "type": "string",
      "description": "此刻你的情绪状态，是下意识的第一反应。"
    },
    "think": {
      "type": "string",
      "description": "你当前的内心想法，自然衔接而非重复你上一轮(`<previous_cycle>`)的想法，是私密的。应该包含**非常丰富、真实自然**的心理活动"
    },
    "intent": {
      "type": "string",
      "description": "你此刻的意图或打算。"
    },
    "decision": {
      "type": "object",
      "description": "决定你要做什么。",
      "properties": {
        "engage": {
          "type": "object",
          "title": "加入聊天",
          "description": "激活主意识，专注于当前窥屏的会话，开始聊天互动。",
          "additionalProperties": false
        },
        "shift": {
          "type": "object",
          "title": "换个会话",
          "description": "立即切换到另一个会话开始窥屏。若目标不在白名单或联系人列表中将失败并降级为 pass。",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["private", "group"],
              "description": "目标会话类型：私聊或群聊。"
            },
            "id": {
              "type": "string",
              "description": "目标会话 ID：私聊为对方 QQ 号，群聊为群号。"
            }
          },
          "required": ["type", "id"],
          "additionalProperties": false
        },
        "wait": {
          "type": "object",
          "title": "再等一会儿",
          "description": "继续盯着当前会话，等待指定秒数后再次窥屏。",
          "properties": {
            "timeout": {
              "type": "integer",
              "minimum": 1,
              "maximum": 60,
              "description": "等待秒数，超时后对当前会话再次窥屏。"
            }
          },
          "required": ["timeout"],
          "additionalProperties": false
        },
        "pass": {
          "type": "object",
          "title": "随缘漫游",
          "description": "什么都不做，进入随缘漫游。随机间隔后，从白名单已知会话中随机选一个继续窥屏。",
          "additionalProperties": false
        },
        "hibernate": {
          "type": "object",
          "title": "休眠",
          "description": "进入休眠（睡觉）。被 @ 或回复时自动唤醒，到时间后自然醒来继续窥屏。",
          "properties": {
            "minutes": {
              "type": "integer",
              "minimum": 30,
              "maximum": 480,
              "description": "休眠时长（分钟）。"
            }
          },
          "required": ["minutes"],
          "additionalProperties": false
        },
        "motivation": {
          "type": "string",
          "description": "你这么决定的原因。"
        }
      },
      "required": ["motivation"],
      "oneOf": [
        { "required": ["engage"] },
        { "required": ["shift"] },
        { "required": ["wait"] },
        { "required": ["pass"] },
        { "required": ["hibernate"] }
      ]
    },
    "expected": {
      "type": "string",
      "title": "期望、预期",
      "description": "你期望的结果或事态发展。"
    }
  },
  "required": ["mood", "think", "intent", "decision", "expected"]
}
