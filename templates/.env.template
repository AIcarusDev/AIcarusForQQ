# AIcarusForQQ Environment Configuration Example
# Copy this file to .env and fill in your API keys.

# DashScope API Key
# Get it from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# SiliconFlow API Key
# Get it from: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# BigModel (Zhipu AI) API Key
# Get it from: https://open.bigmodel.cn/
BIGMODEL_API_KEY=your_bigmodel_api_key_here

# Tavily API Key (Web Search & Extract)
# Get it from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Proxy Configuration (Optional)
# Leave empty to disable proxy for each service; supported formats: http://host:port or socks5://host:port
# For example: OPENAI_PROXY=http://proxy.example.com:8080
OPENAI_PROXY=
TAVILY_PROXY=

# Optional: Override default port via environment variable (if supported by run.py)
# PORT=8080
