# ==========================================
#  AIcarusForQQ 基本配置
#  (此文件仅供模板参考，请创建 config_user.yaml 进行覆盖)
# ==========================================

# ── 1. 模型供应商（统一 OpenAI 兼容）─────────────────────────
#
# API Key 配置方式：
#   A. [推荐] 通过 WebUI 的“模型供应商”页面维护，页面会自动把密钥写入 .env
#   B. 手动在项目根目录 .env 中填写对应的 api_key_env
#
# 这里只维护“供应商”的连接信息：名称 / base_url / api_key_env。
# 各个模型消费点只负责选择 provider 并填写 model。

model_providers:
  siliconflow:
    name: "硅基流动 (SiliconFlow)"
    base_url: "https://api.siliconflow.cn/v1"
    api_key_env: "SILICONFLOW_API_KEY"
  dashscope:
    name: "阿里云百炼 (DashScope)"
    base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
    api_key_env: "DASHSCOPE_API_KEY"
  bigmodel:
    name: "智谱 (BigModel)"
    base_url: "https://open.bigmodel.cn/api/paas/v4"
    api_key_env: "BIGMODEL_API_KEY"
  lmstudio:
    name: "LM Studio（本地）"
    base_url: "http://localhost:1234/v1"
    api_key_env: ""
    requires_api_key: false
    supports_response_format: false

# 当前主模型使用的供应商与模型 ID
provider: "siliconflow"

# --- 模型 ID ---
# 阿里云百炼示例:   "qwen3.5-flash" | "qwen3.5-plus"
# 硅基流动示例:     "Pro/zai-org/GLM-5" | "deepseek-ai/DeepSeek-V3"
# 智谱示例:         "glm-5" | "glm-4-air"
# LM Studio 示例:   "google/gemma-4-27b-it" | 你本地加载的模型 ID
model: "Pro/zai-org/GLM-5"

# ── 显式绑定示例 ────────────────────────────────────────
# 硅基流动 GLM-5:
#   provider: "siliconflow"
#   model: "Pro/zai-org/GLM-5"
#
# 智谱 GLM-5:
#   provider: "bigmodel"
#   model: "glm-5"
#
# 阿里云百炼 Qwen3.5-Flash:
#   provider: "dashscope"
#   model: "qwen3.5-flash"
#
# LM Studio（本地推理服务器）:
#   provider: "lmstudio"
#   model: "gemma-3-27b-it"  # 填 LM Studio 中加载的模型 ID
#   vision: false  # 如果加载的不是 VLM，建议设为 false

# --- 生成参数 ---
generation:
  temperature: 1.0 # 创造性 (0.0 ~ 2.0)
  max_output_tokens: 10000 # 最大输出 token 数
  retry_on_new_message: true # LLM 思考期间有新消息到达时，丢弃本次结果并重新调用一次
  final_reminder: true # 连发提醒：bot 连续发多条消息后插入提示块，防止催促对方回复

# --- 时区 ---
timezone: "Asia/Shanghai"

# --- 模型显示名称（内部可选；未填写时默认等于 model） ---
model_name: "Pro/zai-org/GLM-5"

# --- 速率限制 ---
max_calls_per_minute: 15 # 每分钟最大 LLM 调用次数，达到上限后自动顺延至下一分钟

# --- 聊天上下文窗口 ---
max_context: 10 # 每个会话保留的最大消息条数

# --- 机器人信息 ---
bot_name: "AIcarus"

# --- 监护人信息（可选，留空则不在 system prompt 中显示）---
guardian:
  name: ""
  id: ""

# --- Prompt 文档路径（相对路径按项目根目录解析） ---
prompt_files:
  persona: "data/persona.md"
  style: "data/style.md"
  social_tips_private: "data/social_tips/private.md"
  social_tips_group: "data/social_tips/group.md"

# --- 模拟打字速度 ---
# 打字速度倍率，值越大打字越快，延迟越短，封顶时间也同步缩放
# 可选卡点值: 0.5(很慢) / 0.75(慢) / 1.0(标准) / 1.5(快) / 2.0(很快)
typing_speed: 1.0

# --- 服务器 ---
server:
  port: 5000
  debug: true

# ══════════════════════════════════════════
#  TTS 插件服务端（可选）
#  主程序作为 WebSocket Server，外部 TTS Worker 作为 Client 连接。
# ══════════════════════════════════════════
tts:
  enabled: false
  host: "127.0.0.1"
  port: 8765
  secret_token: ""
  max_concurrent_tasks_per_plugin: 8

# --- 长期记忆 ---
memory:
  max_active: 8 # 模型主动写入（write_memory 工具）的记忆上限
  max_passive: 15 # 系统自动归档（memory_archiver）的记忆上限
  auto_archive:
    # --- 记忆提取专用模型（显式绑定）---
    provider: "siliconflow"
    model: "Pro/zai-org/GLM-5"
    generation:
      temperature: 0.3 # 归档提取模型温度（低温更稳定结构化输出）
      max_output_tokens: 10000 # 归档提取最大输出 token 数

# --- 主动思考（think_deeply 工具） ---
# 主模型可调用 think_deeply，把一个念头丢给“内在思考子模型”。
# 这里也使用显式 provider + model 绑定。
slow_thinking:
  enabled: true
  provider: "siliconflow"
  model: "Pro/zai-org/GLM-5"
  generation:
    temperature: 1.0
    max_output_tokens: 10000

# ══════════════════════════════════════════
#  NapCat 集成（直连 QQ）
# ══════════════════════════════════════════
napcat:
  enabled: true # 设为 true 启用 NapCat 连接
  host: "127.0.0.1" # WebSocket 服务监听地址
  port: 8078 # WebSocket 服务端口（NapCat 配置反向 WS 连接到这里）
  debug_only: false # 设为 true 时只广播 XML 调试，完全不调用 LLM
  # 白名单：空列表则不限制；非空则只响应列表内的用户/群组
  whitelist:
    private_users:  # 私聊白名单，填 QQ 号
      - "1111111111"
    group_ids:      # 群聊白名单，填群号；空列表则响应所有群
      - "1111111111"
  recovery:
    enabled: true # 连接恢复后自动补拉离线消息与更早历史
    page_size: 50 # 每次向 NapCat 拉取多少条消息
    max_pages_per_session: 0 # 每个会话每轮最多翻多少页；0 = 不限
    backfill_history: true # 是否持续向更早历史回填，直到没有更早记录
    seed_from_whitelist: true # 即使本地还没有会话，也为白名单会话建立历史镜像

# ══════════════════════════════════════════
#  Vision Bridge（视觉桥）
#  当主模型不支持视觉（vision: false）或需要精查图片细节时，
#  由独立 VLM 生成图片描述并缓存到 data/image_cache/。
#  同一张图（即便经过 JPEG 重压缩）只描述一次，后续复用。
# ══════════════════════════════════════════
vision_bridge:
  enabled: false             # true = 启用自动描述；false = 只做 pHash 落盘，不调 VLM
  model: "Qwen/Qwen2-VL-7B-Instruct"
  base_url: "https://api.siliconflow.cn/v1"
  api_key_env: "SILICONFLOW_API_KEY"     # .env 中对应的环境变量名
  describe_prompt: "请用2-4句话描述这张图片的主要内容，重点识别其中的文字、数字、人物、场景和关键视觉元素。描述要简洁、客观。"
  similarity_threshold: 10  # 感知哈希汉明距离阈值，≤此值视为同一张图（0=精确匹配）
  whitelist:
    private_users: []        # 只响应列表内的私聊用户，空列表则不限制
  # 缓存清理策略（每次启动时执行一次）
  cache_eviction:
    max_age_days: 30         # 超过此天数的缓存图片将被删除，0 = 不按时间清理
    max_size_mb: 500         # 缓存目录总大小上限(MB)，超出则淘汰最旧的条目，0 = 不限大小
