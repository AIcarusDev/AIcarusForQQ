# ==========================================
#  AIcarusForQQ 基本配置
#  (此文件仅供模板参考，请创建 config_user.yaml 进行覆盖)
# ==========================================

# ── 1. 模型提供商 ────────────────────────────────────
#
# API Key 配置方式 (推荐二选一):
#   A. [推荐] 在项目根目录创建 .env 文件，填入 GEMINI_API_KEY=xxx
#   B. 在系统环境变量中设置 GEMINI_API_KEY
#
# 此配置仅决定使用哪个 Provider，不包含 Key 本身。

# 可选值: gemini | siliconflow | bigmodel
provider: "gemini"

# --- 模型 ID ---
# Gemini 示例:      "gemini-2.0-flash" | "gemini-1.5-pro-latest"
# 硅基流动示例:     "THUDM/GLM-4-32B-0414" | "deepseek-ai/DeepSeek-V3"
# 智谱示例:         "glm-4-plus" | "glm-4-air"
model: "gemini-2.0-flash"

# --- 是否启用视觉（图片理解）---
# false（默认）: 过滤掉消息中的图片，仅发送文本，适合纯文本模型。
# true: 将图片原样发送给模型，需确保所选模型支持视觉输入（VLM）。
vision: true

# --- API 地址（OpenAI 兼容 provider 必填，gemini 忽略）---
# 硅基流动: "https://api.siliconflow.cn/v1"
# 智谱:     "https://open.bigmodel.cn/api/paas/v4"
# base_url: "https://api.siliconflow.cn/v1"

# ── 快速切换配置示例 ────────────────────────────────────
# 硅基流动 GLM-5:
#   provider: "siliconflow"
#   model: "Pro/zai-org/GLM-5"
#   base_url: "https://api.siliconflow.cn/v1"
#
# 智谱 GLM-5:
#   provider: "bigmodel"
#   model: "glm-5"
#   base_url: "https://open.bigmodel.cn/api/paas/v4"

# --- 生成参数 ---
generation:
  temperature: 1.0 # 创造性 (0.0 ~ 2.0)
  max_output_tokens: 8192 # 最大输出 token 数
  max_tool_rounds: 10 # 工具调用最大轮数，防止模型死循环（默认 3）
  json_self_repair_retries: 1 # JSON 解析失败时，让模型自行修复的最大次数（0 = 关闭；默认 1）

# --- 时区 ---
timezone: "Asia/Shanghai"

# --- 模型显示名称（给 LLM 看的） ---
model_name: "Gemini 3.1 Flash Lite"

# --- 思维链（Gemini 原生 thinking_level，其他 provider 忽略）---
# 可选值: minimal / low / medium / high
thinking:
  level: "high"

# --- 循环管理 ---
max_cycles: 5 # 机器人最多可以连续主动循环几次

# --- 机器人信息 ---
bot_name: "Gemini"

# --- 服务器 ---
server:
  port: 5000
  debug: true

# ══════════════════════════════════════════
#  NapCat 集成（直连 QQ）
# ══════════════════════════════════════════
napcat:
  enabled: true # 设为 true 启用 NapCat 连接
  host: "127.0.0.1" # WebSocket 服务监听地址
  port: 8078 # WebSocket 服务端口（NapCat 配置反向 WS 连接到这里）
  debug_only: false # 设为 true 时只广播 XML 调试，完全不调用 LLM
  # 白名单：空列表则不限制；非空则只响应列表内的用户/群组
  whitelist:
    private_users:  # 私聊白名单，填 QQ 号
      - "1111111111"
    group_ids:      # 群聊白名单，填群号；空列表则响应所有群
      - "1111111111"
